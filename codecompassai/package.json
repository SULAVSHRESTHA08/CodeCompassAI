{
  "name": "codecompassai",
  "displayName": "CodeCompassAI",
  "publisher": "codecompass",
  "description": "A VSCode extension that helps  remember What I was doing on my code When I come back after a break.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codecompassai.helloWorld",
        "title": "CodeCompassAI"
      },
      {
        "command": "codecompassai.showSessionSummary",
        "title": "CodeCompass: Show Session Summary"
      },
      {
        "command": "codecompassai.resumeWork",
        "title": "COdeCompass: Resume Work"
      },
      {
        "command": "codecompassai.setApiKey",
        "title": "CodeCompass: Set Gemini API Key"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
